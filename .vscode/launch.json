{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "main:app",
        "--host", "0.0.0.0",
        "--port", "18000",
        "--reload",
        "--reload-dir", "app"
      ],
      "jinja": true
    }
  ]
}